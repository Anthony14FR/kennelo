{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm:watch:routes\" \"pnpm:dev:next\"",
    "dev:next": "dotenv -e .env -- next dev --turbopack",
    "dev:mobile": "dotenv -e .env.mobile -- concurrently \"pnpm:watch:routes\" \"pnpm:dev:next\"",
    "build": "pnpm generate:routes && dotenv -e .env -- next build",
    "build:mobile": "dotenv -e .env.mobile -- pnpm generate:routes && next build",
    "sync:ios": "pnpm build:mobile && npx cap sync ios",
    "sync:android": "pnpm build:mobile && npx cap sync android",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "generate:routes": "node lib/scripts/generate-routes.mjs",
    "watch:routes": "node --watch-path=./app lib/scripts/generate-routes-watch.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@workspace/modules": "workspace:*",
    "@workspace/ui": "workspace:*",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.6.2",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
