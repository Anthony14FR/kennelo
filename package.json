{
    "name": "kennelo",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "lint:fix": "turbo lint:fix",
        "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
        "barrels": "turbo run barrels",
        "clean": "pnpm --recursive exec rm -rf node_modules .turbo .next dist out && pnpm store prune",
        "build:translations": "pnpm --filter @workspace/translations build"
    },
    "devDependencies": {
        "@types/node": "^25.1.0",
        "@workspace/eslint-config": "workspace:*",
        "@workspace/prettier-config": "workspace:*",
        "@workspace/typescript-config": "workspace:*",
        "barrelsby": "^2.8.1",
        "prettier": "^3.8.1",
        "turbo": "^2.8.1",
        "typescript": "5.9.3"
    },
    "packageManager": "pnpm@10.4.1",
    "engines": {
        "node": ">=20"
    },
    "pnpm": {
        "overrides": {
            "sharp": "^0.33.0"
        }
    }
}
